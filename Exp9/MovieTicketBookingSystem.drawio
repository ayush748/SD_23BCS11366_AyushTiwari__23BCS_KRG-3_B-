        <mxCell id="djDakzdJQ-mA7DHJ636W-7" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h2 data-section-id=&quot;19ag4wf&quot; data-start=&quot;687&quot; data-end=&quot;700&quot;&gt;API design&lt;/h2&gt;&#xa;&lt;ul data-start=&quot;701&quot; data-end=&quot;1079&quot;&gt;&#xa;&lt;li data-section-id=&quot;17gya6z&quot; data-start=&quot;701&quot; data-end=&quot;740&quot;&gt;&#xa;&lt;code data-start=&quot;703&quot; data-end=&quot;724&quot;&gt;POST /auth/register&lt;/code&gt; → register user&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1nningq&quot; data-start=&quot;741&quot; data-end=&quot;769&quot;&gt;&#xa;&lt;code data-start=&quot;743&quot; data-end=&quot;761&quot;&gt;POST /auth/login&lt;/code&gt; → login&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;vr9ri9&quot; data-start=&quot;770&quot; data-end=&quot;799&quot;&gt;&#xa;&lt;code data-start=&quot;772&quot; data-end=&quot;785&quot;&gt;GET /movies&lt;/code&gt; → list movies&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;ifxk8m&quot; data-start=&quot;800&quot; data-end=&quot;836&quot;&gt;&#xa;&lt;code data-start=&quot;802&quot; data-end=&quot;820&quot;&gt;GET /movies/{id}&lt;/code&gt; → movie details&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;orz0al&quot; data-start=&quot;837&quot; data-end=&quot;881&quot;&gt;&#xa;&lt;code data-start=&quot;839&quot; data-end=&quot;861&quot;&gt;GET /shows/{movieId}&lt;/code&gt; → shows for a movie&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1g2as5i&quot; data-start=&quot;882&quot; data-end=&quot;925&quot;&gt;&#xa;&lt;code data-start=&quot;884&quot; data-end=&quot;905&quot;&gt;GET /seats/{showId}&lt;/code&gt; → seat availability&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1ol0f96&quot; data-start=&quot;926&quot; data-end=&quot;961&quot;&gt;&#xa;&lt;code data-start=&quot;928&quot; data-end=&quot;944&quot;&gt;POST /bookings&lt;/code&gt; → create booking&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;v1vxjw&quot; data-start=&quot;962&quot; data-end=&