          <mxGeometry height="30" width="580" x="610.1800000000001" y="-1090" as="geometry" />
        </mxCell>
        <mxCell id="d-0v2aAO0mLL_qicqKEa-112" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="3. User should be able to select the quantity and move the product/item into the cart." vertex="1">
