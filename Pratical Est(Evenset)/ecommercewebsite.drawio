        <mxCell id="d-0v2aAO0mLL_qicqKEa-107" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="&lt;b&gt;Design Brief:&lt;/b&gt; We have to design an Online shopping platform similar to Amazon / Flipkart that will allow users to purchase mobiles, laptops, cameras, clothes etc." vertex="1">
